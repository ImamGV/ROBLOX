local LocalPlayer = game.Players.LocalPlayer

local function getClosestSurvivor()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then 
        return nil 
    end
    
    local myRoot = character.HumanoidRootPart
    local survivorFolder = workspace:FindFirstChild("Players") and workspace.Players:FindFirstChild("Survivors")
    
    if not survivorFolder then
        warn("Không tìm thấy thư mục Workspace.Players.Survivor!")
        return nil
    end

    local closestSurvivor = nil
    local shortestDistance = math.huge -- Khởi tạo khoảng cách vô hạn

    -- Lặp qua tất cả đối tượng trong folder Survivor
    for _, survivor in ipairs(survivorFolder:GetChildren()) do
        -- Kiểm tra xem đối tượng có phải nhân vật/bot hợp lệ và có RootPart không
        local targetRoot = survivor:FindFirstChild("HumanoidRootPart")
        local humanoid = survivor:FindFirstChildOfClass("Humanoid")
        
        -- Đảm bảo survivor còn sống và không phải là chính mình (nếu mày cũng ở trong đó)
        if targetRoot and survivor ~= character and (not humanoid or humanoid.Health > 0) then
            -- Tính khoảng cách bằng Magnitude (Bỏ qua căn bậc hai để tối ưu hơn nữa nếu cần, nhưng Magnitude là đủ tốt rồi)
            local distance = (myRoot.Position - targetRoot.Position).Magnitude
            
            -- So sánh để tìm khoảng cách nhỏ nhất
            if distance < shortestDistance and distance < (_G.HitboxExaggeratedDistance or 5) then
                shortestDistance = distance
                closestSurvivor = survivor
            end
        end
    end

    return closestSurvivor, shortestDistance
end

