local CurrentFPS = 60

game:GetService('RunService').RenderStepped:Connect(function()
	FrameCounter += 1
	if (tick() - FrameTimer) >= 1 then
		CurrentFPS = FrameCounter
		FrameTimer = tick()
		FrameCounter = 0
	end
	
    pcall(function()
        local pingItem = game:GetService('Stats').Network.ServerStatsItem:FindFirstChild('Data Ping')
        local pingVal = pingItem and pingItem:GetValue() or 0
        Library:SetWatermark(('%s FPS | %s MS'):format(math.floor(CurrentFPS), math.floor(pingVal)))
    end)

    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        -- Cập nhật đồng bộ các thuộc tính Stamina thông qua Module gốc an toàn
        if StaminaScript then
            local plrs = workspace:FindFirstChild("Players")
            local survivors = plrs and plrs:FindFirstChild("Survivors")
            local killers = plrs and plrs:FindFirstChild("Killers")
            
            local isSurvivor = survivors and survivors:FindFirstChild(game.Players.LocalPlayer.Name)
            local isKiller = killers and killers:FindFirstChild(game.Players.LocalPlayer.Name)
            
            if isSurvivor then
                StaminaScript.MaxStamina = _G.MaxStaminaS or 100
                StaminaScript.StaminaGain = _G.StaminaGainS or 30
                StaminaScript.StaminaLoss = _G.StaminaLossS or 10
                StaminaScript.SprintSpeed = _G.SpeedSprintS or 28
            elseif isKiller then
                StaminaScript.MaxStamina = _G.MaxStaminaK or 110
                StaminaScript.StaminaGain = _G.StaminaGainK or 30
                StaminaScript.StaminaLoss = _G.StaminaLossK or 10
                StaminaScript.SprintSpeed = _G.SpeedSprintK or 28
            end
        end

        -- Xử lý tàng hình bằng Animation ID
        local plrsFolder = workspace:FindFirstChild("Players")
        local spectatingFolder = plrsFolder and plrsFolder:FindFirstChild("Spectating")
        if _G.Invisible and (not spectatingFolder or char.Parent ~= spectatingFolder) then
            local anim = char.Humanoid:FindFirstChild("Invisible_Animation")
            if not anim then
                local newAnim = Instance.new("Animation")
                newAnim.Name = "Invisible_Animation"
                newAnim.AnimationId = "rbxassetid://75804462760596"
                local load = char.Humanoid:LoadAnimation(newAnim)
                load:Play(0, 1, 1)
                load:AdjustSpeed(0)
            end
        else
            for _, track in next, char.Humanoid:GetPlayingAnimationTracks() do
                if track.Animation.Name == "Invisible_Animation" then track:Stop() end
            end
        end

        -- Cập nhật Field Of View của Camera nhân vật an toàn
        if char:FindFirstChild("Model") and char.Model:FindFirstChild("FOVMultipliers") and char.Model.FOVMultipliers:FindFirstChild("FOVSetting") then
            char.Model.FOVMultipliers.FOVSetting.Value = _G.MaxFieldOfView and 1.5 or DefaultFOVValue
        end
    end

    -- Đồng bộ điều khiển các UI phụ của trò chơi (Check thực thể tránh sập luồng)
    local pGui = game.Players.LocalPlayer:FindFirstChild("PlayerGui")
    if pGui then
        if pGui:FindFirstChild("PuzzleUI") then pGui.PuzzleUI.Enabled = not _G.UnshowFixUi end
        if pGui:FindFirstChild("TemporaryUI") and pGui.TemporaryUI:FindFirstChild("PlayerInfo") and pGui.TemporaryUI.PlayerInfo:FindFirstChild("CurrentSurvivors") then
            pGui.TemporaryUI.PlayerInfo.CurrentSurvivors.Visible = not _G.HideBar
        end
        if pGui:FindFirstChild("MainUI") and pGui.MainUI:FindFirstChild("MobileUI") and pGui.MainUI.MobileUI:FindFirstChild("Crosshair") then
            pGui.MainUI.MobileUI.Crosshair.Size = _G.Heart and UDim2.new(0.05, _G.SizeHeart, 0.05, _G.SizeHeart) or UDim2.new(0.05, 0, 0.05, 0)
        end
    end

    -- Khóa độ sáng môi trường map
    if _G.Fullbright then
        game.Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
        game.Lighting.Brightness = 1.5
        game.Lighting.GlobalShadows = false
    else
        game.Lighting.OutdoorAmbient = Color3.fromRGB(55, 55, 55)
        game.Lighting.Brightness = 1.5
        game.Lighting.GlobalShadows = true
    end
    
    game.Lighting.FogStart = _G.NoFog and 0 or (game.Lighting:GetAttribute("FogStart") or 0)
    game.Lighting.FogEnd = _G.NoFog and math.huge or (game.Lighting:GetAttribute("FogEnd") or 1000)
    local atmosphere = game.Lighting:FindFirstChildOfClass("Atmosphere")
    if atmosphere then atmosphere.Density = _G.NoFog and 0 or (atmosphere:GetAttribute("Density") or 0.3) end

    -- Tự động lật đồng xu từ xa độc lập
    if _G.AutoFlipCoins then
        local net = game:GetService("ReplicatedStorage"):FindFirstChild("Modules")
        net = net and net:FindFirstChild("Network")
        net = net and net:FindFirstChild("RemoteEvent")
        if net then
            net:FireServer("UseActorAbility", "CoinFlip")
        end
    end
end)

